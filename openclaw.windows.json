{
  "browser": {
    "enabled": true,
    "evaluateEnabled": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "color": "#FF4500",
        "cdpPort": 18800
      },
      "user": {
        "driver": "existing-session",
        "attachOnly": true,
        "color": "#00AA00"
      },
      "chrome-relay": {
        "driver": "extension",
        "attachOnly": true,
        "color": "#0066CC",
        "cdpUrl": "http://127.0.0.1:18792"
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/z-ai/glm-5-turbo"
      },
      "workspace": "D:\\openclaw"
    },
    "list": [
      {
        "id": "browser-order-price",
        "model": "openrouter/z-ai/glm-5-turbo",
        "tools": {
          "profile": "full",
          "alsoAllow": [
            "browser"
          ]
        }
      }
    ]
  },
  "tools": {
    "profile": "coding"
  }
}
