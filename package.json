{
  "name": "openclaw-browser-order-price",
  "version": "1.0.0",
  "description": "Batch browser order-price agent with persistent real Chrome session",
  "main": "scripts/order_price_runner.mjs",
  "scripts": {
    "prepare-login": "node scripts/prepare_login_session.mjs",
    "run-one": "node scripts/order_price_runner.mjs --config config/runner.json",
    "run-batch": "node scripts/order_price_runner.mjs --config config/runner.json",
    "print-config": "node scripts/order_price_runner.mjs --config config/runner.json --print-config",
    "run-multi": "node scripts/multi_account_runner.mjs --config config/multi_runner.json",
    "print-multi-plan": "node scripts/multi_account_runner.mjs --config config/multi_runner.json --print-plan",
    "run-multi-pending": "node scripts/rerun_pending_multi.mjs --config config/multi_runner.json",
    "print-multi-pending-plan": "node scripts/rerun_pending_multi.mjs --config config/multi_runner.json --print-plan"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "playwright-core": "^1.58.2",
    "xlsx": "^0.18.5"
  }
}
